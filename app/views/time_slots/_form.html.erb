<%= form_with(model: time_slot) do |form| %>
  <% if time_slot.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(time_slot.errors.count, "error") %> prohibited this time_slot from being saved:</h2>
      <ul>
        <% time_slot.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, t(".name"), class: "d-block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :start_at, t(".start_time"), class: "d-block" %>
    <%= form.time_field :start_at %>
  </div>

  <div>
    <%= form.label :end_at, t(".end_time"), class: "d-block" %>
    <%= form.time_field :end_at %>
  </div>

  <div>
    <%= form.submit t(".submit_button_text"), class: "btn btn-primary" %>
  </div>
<% end %>

<%= form_for user, url: profile_path, method: :patch do |f| %>
  <div class="form-group row mb-3">
    <%= f.label :name, t("name"), class: "col-sm-2 col-form-label text-start" %>
    <div class="col-sm-10">
      <%= f.text_field :name, class: "col-sm-10 form-control-plaintext", readonly: true %>
    </div>
  </div>
  <div class="form-group row mb-3">
    <%= f.label :email, t("email"), class: "col-sm-2 col-form-label text-start" %>
    <div class="col-sm-10">
      <%= f.text_field :email, class: "col-sm-10 form-control-plaintext", readonly: true %>
    </div>
  </div>
  <div class="form-group row mb-3">
    <%= f.label :nickname, t(".nickname"), class: "col-sm-2 col-form-label text-start" %>
    <div class="col-sm-10">
      <%= f.text_field :nickname, class: "col-sm-10 form-control" %>
    </div>
  </div>
  <div class="form-group row mb-3">
    <%= f.label :password, t(".password"), class: "col-sm-2 col-form-label text-start" %>
    <div class="col-sm-10">
      <%= f.password_field :password, class: "col-sm-10 form-control" %>
    </div>
  </div>
  <%= f.submit t(".submit_button_text"), class: "btn btn-primary my-2" %>
<% end %>

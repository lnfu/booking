<table class="table table-bordered table-fixed table-hover">
  <thead class="text-center">
    <tr>
      <th>
        <div class="mx-auto py-2">
          <%= link_to(raw("&#8249;"), board_path(@room.name, @prev_week_date.year, @prev_week_date.month, @prev_week_date.day), class: "btn-prev") %>
          <%= link_to(raw("&#8250;"), board_path(@room.name, @next_week_date.year, @next_week_date.month, @next_week_date.day), class: "btn-next") %>
        </div>
      </th>
      <% @week_dates.each do |week_date| %>
        <th>
          <div><%= week_date.strftime('%Y-%m-%d') %></div>
          <div><%= week_date.strftime("%A") %></div>
        </th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% @time_slots.each do |time_slot| %>
      <tr>
        <td><%= "#{time_slot.start_at.strftime("%H:%M")} - #{time_slot.end_at.strftime("%H:%M")}" %></td>
        <% @data.each do |day| %>
          <td>
            <%= reservation_info(day, time_slot) %>
          </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
<style>
  .btn-prev, .btn-next {
    width: 30px;
    height: 30px;
    text-align: center;
    display: inline-block;
    text-decoration: none;
    background-color: rgba(var(--bs-link-color-rgb), var(--bs-link-opacity, 1));
    color: white;
    border-radius: 15px;
  }
</style>
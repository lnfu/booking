<div class="text-center my-5 py-5">
  <div class="mx-auto rounded bg-light px-5 py-5">
    <h1 class="display-5 fw-bold my-4"><%= t(".login") %></h1>
    <%= form_tag "/login", class: "my-2" do %>
      <%= hidden_field_tag(:login_method, 'password') %>
      <div class="form-group row mb-3">
        <%= label_tag(:name, t(".name"), class: "col-form-label col-sm-2") %>
        <div class="col-sm-10">
          <%= text_field_tag(:name,nil, placeholder: "Enter your Student ID...", class: "form-control") %>
        </div>
      </div>
      <div class="form-group row mb-3">
        <%= label_tag(:password, t(".password"), class: "col-sm-2") %>
        <div class="col-sm-10">
          <%= password_field_tag(:password, nil, placeholder: "Enter your password...",class: "form-control") %>
        </div>
      </div>
      <%= submit_tag(t(".submit_button_text"), class: "btn btn-primary px-5 py-2 w-100") %>
    <% end %>
    <hr>
    <%= button_to(
      "NYCU OAuth2", 
      login_path, method: :post, 
      params: { login_method: 'oauth' },
      data: {turbo: "false"}, 
      class: "btn btn-info text-light px-5 py-2 w-100"
    ) %>
  </div>
</div>
